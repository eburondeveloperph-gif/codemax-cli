# Eburon Copilot — Environment Variables
# Copy to .env.local for local dev, or set in Vercel dashboard for production

# Firebase (client-side — safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable__...

# PostgreSQL (Supabase direct connection)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Ollama — primary source (local or remote)
OLLAMA_URL=http://localhost:11434

# Additional VPS hosts running Ollama (comma-separated IPs)
# These are probed at port 11434 alongside localhost
EBURON_VPS_HOSTS=168.231.78.113,124.217.83.142

# Manual CLI endpoint override (optional)
EBURON_CLI_ENDPOINT=

# SSH user for remote CLI detection (default: root)
EBURON_SSH_USER=root
# Path to SSH private key (optional, uses default if omitted)
# EBURON_SSH_KEY=~/.ssh/id_rsa

# IPs that are aliases for this machine (comma-separated)
EBURON_LOCAL_IPS=124.217.83.142,2001:4860:7:50c::f9

# Cloudflare/ngrok tunnel URL for exposing local Ollama publicly
# Use when port forwarding isn't available (NAT/firewall)
# Run: cloudflared tunnel --url http://localhost:11434
EBURON_TUNNEL_URL=

# VPS Sandbox tunnel (cloudflare tunnel → nginx serving sandboxes on VPS)
EBURON_SANDBOX_TUNNEL=https://your-tunnel.trycloudflare.com

# ── Client App Deployment ──────────────────────────────────
# GitHub PAT with repo scope — for pushing generated apps to deployment repo
GITHUB_PAT=
# Target repo for client deployments (owner/repo)
DEPLOY_REPO=eburondeveloperph-gif/studious-potato
# Vercel token for Deployments API (instant static deploys)
VERCEL_DEPLOY_TOKEN=
# Vercel project name/ID for the deployment repo (optional)
VERCEL_DEPLOY_PROJECT=
