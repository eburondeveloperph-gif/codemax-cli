# ═══════════════════════════════════════════════════════════════
# Eburon Codemax — Full Production Environment Variables
# Copy to .env.local for local dev, or set in Vercel dashboard
# ═══════════════════════════════════════════════════════════════

# ── Firebase Auth (client-side — NEXT_PUBLIC_ prefix is safe) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Supabase (database + auth) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable__...
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Ollama (primary LLM backend) ──────────────────────────────
# Local: http://localhost:11434
# Remote via tunnel: https://your-tunnel.trycloudflare.com
OLLAMA_URL=http://localhost:11434
# Default model to use (optional, defaults to eburonmax/codemax-v3)
EBURON_MODEL=eburonmax/codemax-v3

# ── OpenCode Agent (3rd autonomous coding agent) ──────────────
# Start with: opencode serve --port 3333 --hostname 0.0.0.0
OPENCODE_URL=http://127.0.0.1:3333
OPENCODE_PROVIDER=ollama
OPENCODE_MODEL=codemax-v3

# ── Remote Hosts & Networking ─────────────────────────────────
# VPS hosts running Ollama (comma-separated IPs, probed at port 11434)
EBURON_VPS_HOSTS=168.231.78.113
# IPs that are aliases for this machine (comma-separated)
EBURON_LOCAL_IPS=124.217.83.142,2001:4860:7:50c::f9
# Manual CLI endpoint override (optional)
EBURON_CLI_ENDPOINT=
# SSH user for remote CLI detection via SSH (default: root)
EBURON_SSH_USER=root
# Path to SSH private key (optional, uses system default)
# EBURON_SSH_KEY=~/.ssh/id_rsa

# ── Cloudflare Tunnel ─────────────────────────────────────────
# Expose local Ollama publicly: cloudflared tunnel --url http://localhost:11434
EBURON_TUNNEL_URL=
# VPS sandbox tunnel (cloudflare → nginx serving sandboxed apps)
EBURON_SANDBOX_TUNNEL=

# ── Client App Deployment Pipeline ────────────────────────────
# GitHub PAT with repo scope for pushing generated apps
GITHUB_PAT=
# Target repo for client app deployments (owner/repo)
DEPLOY_REPO=eburondeveloperph-gif/studious-potato
# Vercel token for instant static deploys via Deployments API
VERCEL_DEPLOY_TOKEN=
# Vercel project name/ID for the deployment target
VERCEL_DEPLOY_PROJECT=

# ── Browserbase (cloud browser for screenshots) ──────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Misc ──────────────────────────────────────────────────────
# VPS host for sandbox deployment (IP or hostname)
VPS_HOST=
# Backup directory for conversation exports
# BACKUP_DIR=./backups
