{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "ollama"
  ],
  "model": "ollama/codemax:latest",
  "small_model": "ollama/codemax:latest",
  "default_agent": "codemax-skill",
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "codemax-skill": {
      "mode": "primary",
      "model": "ollama/codemax:latest",
      "description": "Codemax default coding agent",
      "color": "primary"
    }
  },
  "provider": {
    "ollama": {
      "name": "codemax",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "codemax:latest": {
          "_launch": true,
          "name": "codemax"
        }
      },
      "whitelist": [
        "codemax:latest"
      ],
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "permission": {
    "websearch": "allow"
  }
}
