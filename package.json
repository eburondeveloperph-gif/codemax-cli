{
  "name": "eburon-autopilot",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "maximus-cli": "./bin/maximus-cli.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "maximus-cli": "node ./bin/maximus-cli.js",
    "maximus-cli:dev": "node ./bin/maximus-cli.js run dev",
    "maximus-cli:build": "node ./bin/maximus-cli.js run build",
    "maximus-cli:install": "node ./bin/maximus-cli.js install",
    "cli": "node cli/dist/cli.js",
    "cli:chat": "node cli/dist/cli.js chat",
    "cli:tui": "node cli/dist/cli.js tui",
    "cli:serve": "node cli/dist/server.js",
    "cli:build": "cd cli && npm run build",
    "start:codemax": "node cli/dist/cli.js start",
    "setup": "bash setup.sh",
    "deploy": "bash setup.sh"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.17",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.474.0",
    "next": "^15.2.1",
    "pg": "^8.19.0",
    "postcss": "^8.4.35",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
