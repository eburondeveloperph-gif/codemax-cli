#!/bin/zsh

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ -x "$SCRIPT_DIR/opencode" ]; then
  OPENCODE_BIN="$SCRIPT_DIR/opencode"
elif command -v opencode >/dev/null 2>&1; then
  OPENCODE_BIN="$(command -v opencode)"
else
  echo "opencode binary not found. Install OpenCode first." >&2
  exit 1
fi

export OPENCODE_CLIENT="codemax"
exec "$OPENCODE_BIN" "$@"
